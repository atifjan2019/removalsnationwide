# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules

# package-lock.json is deliberately NOT committed.
#
# Tailwind 4 and eslint pull in wasm32-wasi fallback packages whose @emnapi/*
# dependencies npm resolves differently per platform. Generating the lock on
# Windows prunes that subtree, so Cloudflare's Linux CI fails `npm ci` with
# EUSAGE ("Missing: @emnapi/runtime@1.11.2 from lock file"). With no lock
# committed, CI runs `npm install` and resolves correctly for its own platform.
#
# Trade-off: builds are not byte-reproducible across time. If that becomes a
# problem, generate the lock on Linux (e.g. a GitHub Action running
# `npm install` and committing the result) rather than from a dev machine.
package-lock.json
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — contain the Cloudflare API token. Never commit.
.env*
.dev.vars
.dev.vars.*

# vercel (legacy — the site deploys to Cloudflare Workers now)
.vercel

# cloudflare / opennext build output
/.open-next/
.wrangler/

# NOTE: worker-configuration.d.ts is generated by `wrangler types` but is
# deliberately committed — `next build` typechecks, and it supplies the
# D1Database/R2Bucket types. Ignoring it breaks builds on a fresh clone (CI).

# generated content — regenerated by the prebuild script before every build
/src/generated/

# typescript
*.tsbuildinfo
next-env.d.ts
